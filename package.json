{
  "name": "@wenyan-md/mcp",
  "version": "2.0.3",
  "description": "MCP server for Wenyan, a Markdown formatting tool that allows AI assistants to apply elegant built-in themes and publish articles directly to 微信公众号.",
  "author": "Lei <caol64@gmail.com> (https://github.com/caol64)",
  "license": "Apache-2.0",
  "keywords": [
    "公众号",
    "markdown",
    "文颜",
    "wenyan",
    "wechat",
    "publishing",
    "renderer",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "wenyan-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/caol64/wenyan-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caol64/wenyan-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/caol64/wenyan-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "inspector": "pnpm build && node ./run-inspector.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test:list": "pnpm build && node --env-file=.env.test ./tests/list.js",
    "test:publish": "pnpm build && node --env-file=.env.test ./tests/publish.js",
    "test:register": "pnpm build && node --env-file=.env.test ./tests/registerTheme.js",
    "test:remove": "pnpm build && node --env-file=.env.test ./tests/removeTheme.js",
    "upgrade:core": "pnpm update @wenyan-md/core",
    "prepublishOnly": "pnpm upgrade:core && pnpm build"
  },
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "@wenyan-md/core": "^3.0.9",
    "form-data-encoder": "^4.1.0",
    "formdata-node": "^6.0.3",
    "jsdom": "^27.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^24.3.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "openai": "^6.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0"
  }
}
